# Development gebruikt standaard lokale JSON-events:
# content/blokken/feedback-local/
FEEDBACK_STORE=local

# Productie met Vercel Blob gebruikt automatisch Blob zodra deze token bestaat:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
#
# Optioneel expliciet forceren:
# FEEDBACK_STORE=vercel-blob

# Lokale Blob-test:
# 1. Maak app/viewer/.env.local
# 2. Zet daarin BLOB_READ_WRITE_TOKEN=...
# 3. Run: npm run test:blob-feedback
# 4. Run de app lokaal tegen Blob met: npm run dev:blob-feedback
